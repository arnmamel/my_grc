ALA_DATABASE_URL=sqlite:///audit_manager.db
ALA_SECRET_FILES_DIR=data/secrets
ALA_LOG_DIR=logs
ALA_LOG_LEVEL=INFO
ALA_APP_LOG_FILE=my_grc.log
ALA_AUDIT_LOG_FILE=my_grc-audit.log
ALA_METRICS_LOG_FILE=my_grc-metrics.log
ALA_TRACE_LOG_FILE=my_grc-traces.log
ALA_BACKUP_DIR=data/backups
ALA_WORKSPACE_AUTH_REQUIRED=true
ALA_WORKSPACE_SESSION_TIMEOUT_MINUTES=480
ALA_CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
ALA_CONFLUENCE_SPACE_KEY=SEC
ALA_CONFLUENCE_PARENT_PAGE_ID=123456
ALA_CONFLUENCE_AUTH_MODE=basic
ALA_CONFLUENCE_USERNAME=user@example.com
ALA_CONFLUENCE_API_TOKEN=
ALA_CONFLUENCE_BEARER_TOKEN=
ALA_DEFAULT_AWS_REGION=eu-west-1
